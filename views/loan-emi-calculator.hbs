<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Luitprise Nidhi Ltd.</title>
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
{{> header}}
<body>
    
    <main class="container section">
        <h2 class="section-title">EMI Calculator</h2>
        <div class="card p-4 p-md-5 shadow-sm calculator-container">
            <div class="row align-items-center">
                <div class="col-md-7">
                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-2 align-items-center">
                            <label for="principal-slider" class="form-label mb-0">Loan Amount</label>
                            <div class="input-group" style="width: 150px;">
                                <span class="input-group-text">₹</span>
                                <input type="text" class="form-control text-end" id="principal-input" value="500000">
                            </div>
                        </div>
                        <input type="range" class="form-range" id="principal-slider" min="10000" max="10000000" step="10000" value="500000">
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-2 align-items-center">
                            <label for="interest-slider" class="form-label mb-0">Rate of Interest (p.a)</label>
                            <div class="input-group" style="width: 120px;">
                                <input type="text" class="form-control text-end" id="interest-input" value="8.5">
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <input type="range" class="form-range" id="interest-slider" min="1" max="25" step="0.1" value="8.5">
                    </div>

                    <div class="mb-4">
                        <div class="d-flex justify-content-between mb-2 align-items-center">
                            <label for="tenure-slider" class="form-label mb-0">Loan Tenure</label>
                             <div class="input-group" style="width: 120px;">
                                <input type="text" class="form-control text-end" id="tenure-input" value="5">
                                <span class="input-group-text">Yr</span>
                            </div>
                        </div>
                        <input type="range" class="form-range" id="tenure-slider" min="1" max="30" step="1" value="5">
                    </div>

                    <hr class="my-4">

                    <ul class="results-table">
                        <li><span>Monthly EMI</span><strong id="result-emi"></strong></li>
                        <li><span>Principal Amount</span><strong id="result-principal"></strong></li>
                        <li><span>Total Interest</span><strong id="result-interest"></strong></li>
                        <li><span>Total Amount</span><strong id="result-total"></strong></li>
                    </ul>
                </div>

                <div class="col-md-5 text-center mt-4 mt-md-0">
                    <div class="chart-container">
                        <canvas id="emiChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </main>
    {{> footer}}
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/loan-emi.js"></script>
     <script src="/js/main.js"></script>
    {{> chatbot}}
</body>
</html>