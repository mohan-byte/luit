<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Luitprise Nidhi Ltd.</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    {{> header}}
    <main class="section">
        <div class="container">
            <h2 class="section-title">Pay Loan EMI</h2>
            <div class="card col-md-8 mx-auto p-4 shadow-sm">
                <p class="text-danger">* All fields are mandatory</p>
                <hr>
                {{#if message}}
                <div class="alert {{#if (startsWith message 'Success')}}alert-success{{else}}alert-danger{{/if}}" role="alert">
                    {{substring message (indexOf message ':') 2}}
                </div>
                {{/if}}

                <form action="/payments/submit" method="POST">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="loanAccountNumber" class="form-label">Loan Account Number *</label>
                            <input type="text" class="form-control" id="loanAccountNumber" name="loanAccountNumber" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="mobileNumber" class="form-label">Registered Mobile Number *</label>
                            <input type="text" class="form-control" id="mobileNumber" name="mobileNumber" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="captcha" class="form-label">Verify the captcha *</label>
                        <div class="input-group">
                            <input type="text" class="form-control" id="captcha" name="captcha" required>
                            <div id="captcha-image" class="input-group-text p-0"></div>
                            <button class="btn btn-outline-secondary" type="button" id="reload-captcha"><i class="bi bi-arrow-clockwise"></i></button>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Proceed</button>
                </form>
            </div>
        </div>
    </main>
    {{> footer}}
    {{> chatbot}}
    <script>
        // CAPTCHA Reload Logic
        function loadCaptcha() {
            document.getElementById('captcha-image').innerHTML = `<img src="/payments/captcha?t=${new Date().getTime()}" alt="CAPTCHA">`;
        }
        document.getElementById('reload-captcha').addEventListener('click', loadCaptcha);
        document.addEventListener('DOMContentLoaded', loadCaptcha);
    </script>
<script src="/js/main.js"></script>

    {{> chatbot}}
</body>
</html>