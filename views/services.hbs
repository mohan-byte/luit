<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Luitprise Nidhi Ltd.</title>
     <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    {{> header}}
    <main>
        <section class="section">
            <div class="container">
                <h2 class="section-title">Fixed Deposit Plans</h2>
                <div class="row g-4 justify-content-center">
                    <div class="col-lg-5 col-md-6">
                        <div class="card highlighted-card h-100">
                            <div class="card-body">
                                <h5 class="card-title">Fixed Deposit (FD)</h5>
                                <p class="card-text">A secure way to invest a lump sum for a fixed period with guaranteed returns.</p>
                                <a href="/apply/fixed-deposit" class="btn btn-primary mt-3">Apply Now</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-5 col-md-6">
                        <div class="card highlighted-card h-100">
                            <div class="card-body">
                                <h5 class="card-title">Recurring Deposit (RD)</h5>
                                <p class="card-text">Ideal for regular savings with high-interest returns and a flexible tenure.</p>
                                <a href="/apply/recurring-deposit" class="btn btn-primary mt-3">Apply Now</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-5 col-md-6">
                        <div class="card highlighted-card h-100">
                            <div class="card-body">
                                <h5 class="card-title">Child Savings Plan</h5>
                                <p class="card-text">A secure way to invest a lump sum for a fixed period with guaranteed returns.</p>
                                <a href="#" class="btn btn-primary mt-3">Apply Now</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-5 col-md-6">
                        <div class="card highlighted-card h-100">
                            <div class="card-body">
                                <h5 class="card-title">Retirement Savings</h5>
                                <p class="card-text">Ideal for regular savings with high-interest returns and a flexible tenure.</p>
                                <a href="#" class="btn btn-primary mt-3">Apply Now</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    {{> footer}}
    <script src="/js/main.js"></script>
    {{> chatbot}}
</body>
</html>