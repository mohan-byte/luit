<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Luitprise Nidhi Ltd.</title>
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    {{> header}}
    <main class="section text-center">
        <div class="container">
            <div class="card col-md-6 mx-auto p-4 p-md-5 shadow-sm">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 4rem;"></i>
                <h2 class="mt-3">Application Submitted!</h2>
                <p class="lead">Thank you for applying for the {{planName}} plan.</p>
                <p>Your unique application number is:</p>
                <h3 class="text-primary">{{applicationNumber}}</h3>
                <p class="mt-3 text-muted">You will be notified once your application has been reviewed by our team.</p>
                <a href="/dashboard" class="btn btn-secondary mt-3">Go to Dashboard</a>
            </div>
        </div>
    </main>
    {{> footer}}
    {{> chatbot}}
</body>
</html>