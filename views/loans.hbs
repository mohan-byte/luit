<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Luitprise Nidhi Ltd.</title>
     <link rel="icon" type="image/x-icon" href="/images/favicon.ico">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    {{> header}}
    <main>
        <section class="section">
            <div class="container">
                <h2 class="section-title">Loan Schemes</h2>
                <div class="row g-4 justify-content-center">
                    <div class="col-lg-5 col-md-6">
                        <div class="card highlighted-card h-100">
                            <div class="card-body">
                                <h5 class="card-title">Gold Loan</h5>
                                <p class="card-text">Get instant funds against your gold ornaments with minimal documentation and competitive interest rates.</p>
                                <a href="/apply/gold-loan" class="btn btn-primary mt-3">Apply Now</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-5 col-md-6">
                        <div class="card highlighted-card h-100">
                            <div class="card-body">
                                <h5 class="card-title">Personal Loan</h5>
                                <p class="card-text">Fulfill your personal needs, be it a wedding, vacation, or medical emergency, with our easy-to-avail personal loans.</p>
                                <a href="/apply/personal-loan" class="btn btn-primary mt-3">Apply Now</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>
    {{> footer}}
    <script src="/js/main.js"></script>
    {{> chatbot}}
</body>
</html>