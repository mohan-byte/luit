<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Luitprise Nidhi Ltd.</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container d-flex justify-content-center align-items-center" style="min-height: 100vh;">
        <div class="card p-4 p-md-5 shadow-sm" style="width: 25rem;">
            <div class="text-center mb-4">
                <a href="/"><img src="/images/logo.png" alt="Luitprise Logo" style="height: 60px;"></a>
                <h3 class="mt-3">Complete Your Registration</h3>
                <p class="text-muted">Please create a secure password for your new account.</p>
            </div>
            
            {{#if error}}
            <div class="alert alert-danger">{{error}}</div>
            {{/if}}

            <form action="/complete-registration/{{token}}" method="POST">
                <div class="mb-3">
                    <label for="password" class="form-label">New Password</label>
                    <input type="password" class="form-control" name="password" required>
                </div>
                <div class="mb-3">
                    <label for="confirmPassword" class="form-label">Confirm New Password</label>
                    <input type="password" class="form-control" name="confirmPassword" required>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary">Set Password and Login</button>
                </div>
            </form>
        </div>
    </div>
</body>
</html>