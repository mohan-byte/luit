<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Luitprise Nidhi Ltd.</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    {{> header}}
    <main class="section">
        <div class="container">
            <h2 class="section-title">Welcome, {{user.name}}</h2>
            <div class="card col-md-8 mx-auto p-4 shadow-sm">
                <h4 class="mb-3">Your Application Status</h4>
                {{#if application}}
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex justify-content-between"><strong>Application Number:</strong><span>{{application.applicationNumber}}</span></li>
                        <li class="list-group-item d-flex justify-content-between"><strong>Plan Name:</strong><span>{{application.planName}}</span></li>
                        <li class="list-group-item d-flex justify-content-between"><strong>Status:</strong>
                            <span class="badge {{#ifeq application.status 'Approved'}}bg-success{{else ifeq application.status 'Rejected'}}bg-danger{{else}}bg-warning{{/ifeq}}">{{application.status}}</span>
                        </li>
                        <li class="list-group-item d-flex justify-content-between"><strong>Policy Number:</strong><span>{{#if application.policyNumber}}{{application.policyNumber}}{{else}}N/A{{/if}}</span></li>
                    </ul>
                {{else}}
                    <p class="text-center">You have not submitted any applications yet.</p>
                {{/if}}
            </div>
        </div>
    </main>
    {{> footer}}
    {{> chatbot}}
</body>
</html>