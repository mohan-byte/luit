<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Luitprise Nidhi Ltd.</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    {{> header}}
    <main class="section text-center">
        <div class="container">
            <div class="card col-md-6 mx-auto p-4 p-md-5 shadow-sm">
                <h2 class="text-danger">Oops! Something went wrong.</h2>
                <p class="lead mt-3">{{message}}</p>
                <a href="/" class="btn btn-primary mt-3">Go to Homepage</a>
            </div>
        </div>
    </main>
    {{> footer}}
</body>
</html>